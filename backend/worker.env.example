# Supabase (use a service role key — nunca a anon key)
SUPABASE_URL=https://SEU-PROJECT-REF.supabase.co
SUPABASE_KEY=SEU-SERVICE-ROLE-KEY

# CUPS — nome exato da impressora (veja: lpstat -p)
PRINTER_NAME=DNP_RX1

# Storage bucket onde os PNGs compostos ficam
STORAGE_BUCKET=prints

# Tentativas em caso de falha
MAX_RETRIES=3
RETRY_DELAY=5

# Polling do CUPS (quanto esperar entre verificações se o papel saiu)
CUPS_POLL_INTERVAL=3
CUPS_TIMEOUT=300
